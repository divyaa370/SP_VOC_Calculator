# ── Required ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co    # Your Supabase project URL
VITE_SUPABASE_ANON_KEY=your_anon_key_here      # Supabase anon/public key (safe to expose in client)
                                                # NEVER put the service_role key here

# ── Optional ──────────────────────────────────────────────────────────────────
VITE_APP_URL=https://truecost.app              # Full origin URL (used in password-reset email links)

# EIA (U.S. Energy Information Administration) API key — free registration at:
# https://www.eia.gov/opendata/register.php
# Powers live gas price and electricity rate updates.
# If unset, the app falls back to hardcoded constants in src/lib/constants.ts.
VITE_EIA_API_KEY=
